<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Module category -->
        <record id="module_category_dkm" model="ir.module.category">
            <field name="name">Digital Kamtibmas</field>
            <field name="sequence">50</field>
        </record>

        <!-- Privilege (grup di dropdown user) — Odoo 19: res.groups.privilege -->
        <record id="privilege_dkm_access" model="res.groups.privilege">
            <field name="name">Digital Kamtibmas</field>
            <field name="category_id" ref="module_category_dkm"/>
            <field name="sequence">10</field>
        </record>

        <!-- Admin: akses penuh -->
        <record id="group_dkm_admin" model="res.groups">
            <field name="name">Admin</field>
            <field name="privilege_id" ref="privilege_dkm_access"/>
        </record>

        <!-- Operator: CRUD tanpa delete -->
        <record id="group_dkm_operator" model="res.groups">
            <field name="name">Operator</field>
            <field name="privilege_id" ref="privilege_dkm_access"/>
        </record>

    </data>
</odoo>
