<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List -->
    <record id="view_dkm_kecamatan_list" model="ir.ui.view">
        <field name="name">dkm.kecamatan.list</field>
        <field name="model">digital_kamtibmas.kecamatan</field>
        <field name="arch" type="xml">
            <list string="Kecamatan">
                <field name="name"/>
                <field name="code"/>
                <field name="kabupaten_id"/>
                <field name="desa_count" string="Desa/Kel."/>
            </list>
        </field>
    </record>

    <!-- Form -->
    <record id="view_dkm_kecamatan_form" model="ir.ui.view">
        <field name="name">dkm.kecamatan.form</field>
        <field name="model">digital_kamtibmas.kecamatan</field>
        <field name="arch" type="xml">
            <form string="Kecamatan">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="kabupaten_id"/>
                        </group>
                        <group>
                            <field name="desa_count" string="Total Desa/Kel."/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Desa/Kelurahan" name="desa">
                            <field name="desa_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="code"/>
                                    <field name="type"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search -->
    <record id="view_dkm_kecamatan_search" model="ir.ui.view">
        <field name="name">dkm.kecamatan.search</field>
        <field name="model">digital_kamtibmas.kecamatan</field>
        <field name="arch" type="xml">
            <search string="Cari Kecamatan">
                <field name="name" string="Nama"/>
                <field name="code" string="Kode"/>
                <field name="kabupaten_id" string="Kabupaten"/>
                <group>
                    <filter string="Kabupaten" name="group_kab" context="{'group_by': 'kabupaten_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_dkm_config_kecamatan" model="ir.actions.act_window">
        <field name="name">Kecamatan</field>
        <field name="res_model">digital_kamtibmas.kecamatan</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_dkm_kecamatan_search"/>
    </record>

</odoo>
