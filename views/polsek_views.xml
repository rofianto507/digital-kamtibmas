<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List -->
    <record id="view_dkm_polsek_list" model="ir.ui.view">
        <field name="name">dkm.polsek.list</field>
        <field name="model">digital_kamtibmas.polsek</field>
        <field name="arch" type="xml">
            <list string="Polsek">
                <field name="name"/>
                <field name="kecamatan_id"/>
                <field name="kabupaten_id"/>
            </list>
        </field>
    </record>

    <!-- Form -->
    <record id="view_dkm_polsek_form" model="ir.ui.view">
        <field name="name">dkm.polsek.form</field>
        <field name="model">digital_kamtibmas.polsek</field>
        <field name="arch" type="xml">
            <form string="Polsek">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="kecamatan_id"/>
                            <field name="kabupaten_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search -->
    <record id="view_dkm_polsek_search" model="ir.ui.view">
        <field name="name">dkm.polsek.search</field>
        <field name="model">digital_kamtibmas.polsek</field>
        <field name="arch" type="xml">
            <search string="Cari Polsek">
                <field name="name" string="Nama Polsek"/>
                <field name="kecamatan_id" string="Kecamatan"/>
                <field name="kabupaten_id" string="Kabupaten"/>
                <group>
                    <filter string="Kecamatan" name="group_kec" context="{'group_by': 'kecamatan_id'}"/>
                    <filter string="Kabupaten" name="group_kab" context="{'group_by': 'kabupaten_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_dkm_config_polsek" model="ir.actions.act_window">
        <field name="name">Polsek</field>
        <field name="res_model">digital_kamtibmas.polsek</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_dkm_polsek_search"/>
    </record>

</odoo>
